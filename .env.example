# ═══════════════════════════════════════════════════════════════
#  JoelBot V20.0 — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com seus valores reais
# ═══════════════════════════════════════════════════════════════

# ─── OBRIGATÓRIAS ────────────────────────────────────────────
# Token do bot Telegram (obtenha com @BotFather)
TELEGRAM_TOKEN=seu_token_telegram_aqui

# Chave API da Groq (obtenha em console.groq.com)
GROQ_API_KEY=gsk_sua_chave_groq_aqui

# ─── OPCIONAIS (Skills) ───────────────────────────────────────

# GitHub Personal Access Token (github.com/settings/tokens)
# Escopos necessários: repo, read:user
GITHUB_TOKEN=ghp_seu_token_github_aqui

# Google Drive OAuth2 Access Token
# Obtenha via Google OAuth2 Playground (developers.google.com/oauthplayground)
# Escopos: https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_TOKEN=ya29_seu_token_drive_aqui

# Replicate API Token (para geração de vídeos)
# Obtenha em replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_seu_token_replicate_aqui

# ─── SERVIDOR ────────────────────────────────────────────────
# Porta do Web Terminal (padrão: 3000 local / 10000 no Render)
# No Render, a variável PORT é definida automaticamente
PORT=3000
