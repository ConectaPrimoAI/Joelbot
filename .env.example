# ══════════════════════════════════════════════
#  JoelBot V20.0 — Variáveis de Ambiente
# ══════════════════════════════════════════════

# ── OBRIGATÓRIOS ──────────────────────────────
TELEGRAM_TOKEN=          # @BotFather
GROQ_API_KEY=            # console.groq.com

# ── GOOGLE (Gmail + Drive) ────────────────────
# Token OAuth2 com escopos: gmail.* + drive.*
# Gere em: console.cloud.google.com → Credentials → OAuth2
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GITHUB ────────────────────────────────────
# Personal Access Token com scope: repo, delete_repo
GITHUB_TOKEN=
GITHUB_USERNAME=         # seu username no GitHub

# ── REPLICATE (Vídeos) ────────────────────────
REPLICATE_API_TOKEN=     # replicate.com

# ── SERVIDOR ──────────────────────────────────
PORT=10000
WEB_TERMINAL_PORT=3000

# ── CHROME (BrowserSkill) ─────────────────────
# Deixe vazio para usar o Chrome baixado pelo puppeteer
# No Render: /usr/bin/google-chrome-stable
CHROME_PATH=
